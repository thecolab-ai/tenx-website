---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { href } from "../../lib/href";
import { collectionPageSchema } from "../../lib/seo";

const unsortedPosts: CollectionEntry<"blog">[] = await getCollection("blog");
const posts = unsortedPosts.sort(
  (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="AI engineering hiring articles"
  description="Dense tenX guides on hiring AI engineers, verification, transparent pricing, and model-agnostic engineering talent."
  path="/blog"
  breadcrumbs={[{ name: "Home", path: "/" }, { name: "Blog", path: "/blog" }]}
  schema={collectionPageSchema({
    title: "tenX blog",
    description: "Articles about AI engineering hiring and verification.",
    path: "/blog"
  })}
>
  <section class="container section">
    <div class="max-w-3xl">
      <p class="eyebrow">Blog</p>
      <h1 class="mt-4 text-5xl font-black leading-tight md:text-6xl">Operator-grade notes on AI engineering hiring.</h1>
      <p class="mt-6 text-xl leading-8 text-[var(--muted)]">
        Lead-with-answer guides for founders, CTOs, and engineering leaders hiring model-fluent engineers.
      </p>
    </div>
    <div class="mt-10 grid gap-4">
      {posts.map((post) => (
        <a class="card p-6 hover:border-[var(--accent)]" href={href(`/blog/${post.id}`)}>
          <p class="mono text-sm text-[var(--accent)]">
            {post.data.pubDate.toLocaleDateString("en-NZ", { day: "numeric", month: "long", year: "numeric" })}
          </p>
          <h2 class="mt-3 text-3xl font-black">{post.data.title}</h2>
          <p class="mt-4 max-w-3xl leading-7 text-[var(--muted)]">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
