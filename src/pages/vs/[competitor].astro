---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BrandText from "../../components/BrandText.astro";
import TenX from "../../components/TenX.astro";
import { allCompetitors, type Competitor } from "../../lib/data";
import { href } from "../../lib/href";
import { collectionPageSchema } from "../../lib/seo";

export function getStaticPaths() {
  return allCompetitors.map((competitor) => ({
    params: { competitor: competitor.slug },
    props: { competitor }
  }));
}

interface Props {
  competitor: Competitor;
}

const { competitor } = Astro.props;
const title = competitor.headline;
const description = `${competitor.positioning} Compare verification, pricing visibility, geography, and AI-specific depth.`;
const path = `/vs/${competitor.slug}`;
const rows = [
  ["AI-specific verification", "Practical tests and badges across Claude, OpenAI, Google, RAG, agents, evals, MLOps, and code-with-AI.", competitor.aiVerification],
  ["Pricing", "10% permanent placement fee. 20% contractor loading on monthly billings.", competitor.pricingModel],
  ["Margin visibility", "Published before the first call.", competitor.marginNote],
  ["Launch geography", "NZ first, AUS second, US/UK/EU later.", "Depends on the competitor's global marketplace coverage."],
  ["Candidate priority", "More relevant badges increase match priority.", "Usually based on platform vetting, marketplace matching, or recruiter review."]
];
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  breadcrumbs={[{ name: "Home", path: "/" }, { name: "Comparisons", path: path }, { name: competitor.name, path }]}
  schema={collectionPageSchema({ title, description, path })}
>
  <section class="container section">
    <div class="max-w-4xl">
      <p class="eyebrow">Comparison</p>
      <h1 class="mt-4 text-5xl font-medium leading-tight md:text-6xl"><BrandText text={title} /></h1>
      <p class="mt-6 text-xl leading-8 text-[var(--muted)]"><BrandText text={competitor.positioning} /></p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="button button-primary" href={href("/pricing")}>View <TenX /> pricing</a>
        <a class="button button-secondary" href={href("/hire")}>Join employer waitlist</a>
      </div>
    </div>
  </section>

  <section class="border-y border-[var(--line)] bg-[var(--bg-elevated)]">
    <div class="container py-16">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[820px] border-collapse text-left text-sm">
          <thead>
            <tr>
              <th class="border border-[var(--line)] bg-[var(--surface)] p-4">Dimension</th>
              <th class="border border-[var(--line)] bg-[var(--surface)] p-4"><TenX /></th>
              <th class="border border-[var(--line)] bg-[var(--surface)] p-4">{competitor.name}</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr>
                <td class="border border-[var(--line)] p-4 font-bold">{row[0]}</td>
                <td class="border border-[var(--line)] p-4"><BrandText text={row[1]} /></td>
                <td class="border border-[var(--line)] p-4"><BrandText text={row[2]} /></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-5 text-sm leading-6 text-[var(--faint)]">
        Competitor context source: <a class="text-[var(--accent)] underline" href={competitor.sourceUrl}>{competitor.sourceLabel}</a>.
        Pricing and margin details can change; rumoured margins are labelled as rumoured, not official disclosures.
      </p>
    </div>
  </section>

  <section class="container section grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
    <div>
      <p class="eyebrow">The <TenX /> angle</p>
      <h2 class="mt-4 text-4xl font-medium">Narrower beats broader when the job is AI engineering.</h2>
    </div>
    <div class="prose-tenx max-w-none">
      <p>
        Broad talent marketplaces can be useful. The <TenX /> bet is that AI engineering now needs a sharper trust layer:
        practical evidence across provider tools, tested implementation patterns, and visible economics.
      </p>
      <p>
        If the hiring brief involves RAG quality, agent design, eval harnesses, MLOps, or code-with-AI throughput, a generic screen is too shallow.
        <TenX /> starts with badge-level verification and then matches candidates to the actual work.
      </p>
    </div>
  </section>

  <section class="container pb-16">
    <div class="grid gap-4 md:grid-cols-3">
      <a class="card p-6 hover:border-[var(--accent)]" href={href("/network")}>
        <p class="eyebrow">Network</p>
        <h3 class="mt-3 text-xl font-medium">See the 100-engineer launch network</h3>
      </a>
      <a class="card p-6 hover:border-[var(--accent)]" href={href("/blog/toptal-vs-turing-vs-tenx-for-ai-engineering")}>
        <p class="eyebrow">Article</p>
        <h3 class="mt-3 text-xl font-medium">Toptal vs Turing vs <TenX /></h3>
      </a>
      <a class="card p-6 hover:border-[var(--accent)]" href={href("/blog/what-makes-an-ai-engineer-verified")}>
        <p class="eyebrow">Verification</p>
        <h3 class="mt-3 text-xl font-medium">What verified means</h3>
      </a>
    </div>
  </section>
</BaseLayout>
