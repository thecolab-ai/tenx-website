---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { faqPageSchema, jobPostingSchema } from "../../../lib/seo";
import { allCities, allRoles, type City, type Role } from "../../../lib/data";

type Props = {
  role: Role;
  city: City;
};

export function getStaticPaths() {
  return allRoles.flatMap((role) =>
    allCities.map((city) => ({
      params: { role: role.slug, city: city.slug },
      props: { role, city }
    }))
  );
}

const { role, city } = Astro.props;
const path = `/hire/${role.slug}/${city.slug}`;
const roleHubPath = `/hire/${role.slug}`;
const isOpen = city.status === "open";
const isAustralia = city.countryCode === "AU";
const marketEyebrow = isAustralia ? "AUS expansion" : "NZ-first AI engineering network";

const formatNumber = new Intl.NumberFormat("en-NZ", {
  maximumFractionDigits: 0
});

function roundToNearestFiveThousand(amount: number): number {
  return Math.round(amount / 5000) * 5000;
}

function formatRange(min: number, max: number): string {
  return `${city.currency} ${formatNumber.format(min)}-${formatNumber.format(max)}`;
}

const salaryMin = roundToNearestFiveThousand(role.salaryMin * city.salaryMultiplier);
const salaryMax = roundToNearestFiveThousand(role.salaryMax * city.salaryMultiplier);
const contractMonthlyMin = roundToNearestFiveThousand(role.contractMonthlyMin * city.salaryMultiplier);
const contractMonthlyMax = roundToNearestFiveThousand(role.contractMonthlyMax * city.salaryMultiplier);
const permanentRange = formatRange(salaryMin, salaryMax);
const contractorRange = `${formatRange(contractMonthlyMin, contractMonthlyMax)} / month`;
const title = `Hire ${role.title} in ${city.name} | tenX`;
const description = `Hire AI-verified, model-fluent ${role.shortTitle} in ${city.name}. tenX matches ${city.countryCode === "AU" ? "AUD" : "NZD"} ${formatNumber.format(salaryMin)}-${formatNumber.format(salaryMax)} permanent talent with verified ${role.skills.slice(0, 3).join(", ")} skills.`;
const lead = `${role.summary} ${city.name} adds local context: ${city.marketNote} tenX verifies model fluency, practical shipping evidence, and role-specific strengths before talent reaches an employer shortlist.`;
const talentStat = `${city.talentCount} engineers in this discipline in ${city.name}`;

const faqs = [
  {
    question: `How fast can tenX surface ${role.shortTitle} in ${city.name}?`,
    answer: isOpen
      ? `For open New Zealand cities, tenX is preparing shortlists for June 2026 employer access. The ${city.name} pool includes ${talentStat.toLowerCase()}, with profiles filtered by ${role.skills.slice(0, 2).join(" and ")} evidence.`
      : `Employer access in ${city.name} opens in June 2026. Candidate intake is already live, so tenX can build an early ${role.title} bench before companies begin posting roles.`
  },
  {
    question: `What salary should employers budget for a ${role.title} in ${city.name}?`,
    answer: `Current tenX guidance for ${city.name} is ${permanentRange} for permanent roles and ${contractorRange} for monthly contract engagements, adjusted by the city salary multiplier and rounded to the nearest 5k.`
  },
  {
    question: `How does tenX verify ${role.shortTitle} before an introduction?`,
    answer: `tenX checks practical work samples, model fluency, AI-assisted delivery habits, and platform badges such as ${role.badges.slice(0, 3).join(", ")}. Employers can inspect these signals before moving candidates into interview loops.`
  }
];

const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Hire", path: "/hire" },
  { name: role.title, path: roleHubPath },
  { name: city.name, path }
];

const schemaDescription = `${role.summary} tenX connects employers with AI-verified ${role.shortTitle} in ${city.name}, with market guidance of ${permanentRange} permanent and ${contractorRange} contractor.`;
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  breadcrumbs={breadcrumbs}
  schema={[
    jobPostingSchema({
      title: `${role.title} in ${city.name}`,
      description: schemaDescription,
      locationName: city.name,
      country: city.country,
      path
    }),
    faqPageSchema(faqs)
  ]}
>
  <section class="container py-12 md:py-16">
    <nav class="mono flex flex-wrap items-center gap-2 text-xs text-[var(--faint)]" aria-label="Breadcrumb">
      <a class="hover:text-[var(--text)]" href="/">Home</a>
      <span>/</span>
      <a class="hover:text-[var(--text)]" href="/hire">Hire</a>
      <span>/</span>
      <a class="hover:text-[var(--text)]" href={roleHubPath}>{role.title}</a>
      <span>/</span>
      <span class="text-[var(--muted)]">{city.name}</span>
    </nav>

    <div class="mt-8 grid gap-10 lg:grid-cols-[0.98fr_1.02fr] lg:items-start">
      <div>
        <p class="eyebrow">{marketEyebrow}</p>
        <h1 class="mt-4 text-5xl font-black leading-tight md:text-6xl">Hire {role.title} in {city.name}</h1>
        <p class="mt-6 text-xl leading-8 text-[var(--muted)]">{lead}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button button-secondary" href="/how-it-works">How verification works</a>
          <a class="button button-secondary" href="/network">Explore the network</a>
          <a class="button button-secondary" href="/pricing">Pricing</a>
        </div>
      </div>

      <aside class="panel p-6 md:p-8">
        {isOpen ? (
          <div class="grid gap-5">
            <div>
              <p class="eyebrow">Employer access</p>
              <h2 class="mt-3 text-2xl font-black">Build a verified shortlist for June 2026.</h2>
              <p class="mt-3 leading-7 text-[var(--muted)]">
                Post the role context once, then tenX filters for model fluency, delivery evidence, and practical fit before candidates reach your team.
              </p>
            </div>
            <div class="grid gap-3 sm:grid-cols-2">
              <a class="button button-primary" href="/hire">Post a role</a>
              <a class="button button-secondary" href="/hire">See all {role.shortTitle}</a>
            </div>
          </div>
        ) : (
          <div class="grid gap-4">
            <p class="eyebrow">Coming June 2026</p>
            <h2 class="text-2xl font-black">Employer access opening soon. Candidates applying now.</h2>
            <p class="leading-7 text-[var(--muted)]">
              Candidates are applying now for the {city.name} launch pool. Employer access opens June 2026, with early demand expected across {role.skills.slice(0, 3).join(", ")} work.
            </p>
            <a class="button button-secondary" href="/apply">Candidate intake is open</a>
          </div>
        )}
      </aside>
    </div>
  </section>

  <section class="container grid gap-6 pb-12 md:grid-cols-3 md:pb-16">
    <div class="card p-6">
      <p class="eyebrow">Permanent</p>
      <p class="mt-3 text-3xl font-black">{permanentRange}</p>
      <p class="mt-3 text-sm leading-6 text-[var(--muted)]">
        Annual salary guidance for {role.title} hiring in {city.name}, adjusted for local market pressure.
      </p>
    </div>
    <div class="card p-6">
      <p class="eyebrow">Contractor</p>
      <p class="mt-3 text-3xl font-black">{contractorRange}</p>
      <p class="mt-3 text-sm leading-6 text-[var(--muted)]">
        Monthly contract budget for project delivery, model integration, evaluation, and production support.
      </p>
    </div>
    <div class="card p-6">
      <p class="eyebrow">City talent</p>
      <p class="mt-3 text-3xl font-black">{city.talentCount}</p>
      <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{talentStat}</p>
    </div>
  </section>

  <section class="container grid gap-8 pb-12 lg:grid-cols-[0.95fr_1.05fr] md:pb-16">
    <div class="panel p-6 md:p-8">
      <p class="eyebrow">Role fit</p>
      <h2 class="mt-3 text-3xl font-black">What {role.shortTitle} ship in {city.name}</h2>
      <div class="prose-tenx">
        <p>
          tenX candidates for this page are screened for work that has moved beyond demos: product flows, internal workflows, retrieval systems, evaluation loops, observability, and human review controls that make model output usable by real teams.
        </p>
        <p>
          For {city.name} employers, the strongest {role.title} profiles usually combine software engineering fundamentals with current model capability. That means knowing when to use GPT, Claude, Gemini, retrieval, tool calling, or conventional code, and being able to explain the reliability and cost tradeoffs behind each choice.
        </p>
        <p>
          The hiring process should stay focused on evidence. Use tenX to compare verified badge signals, salary expectations, contract availability, and city-specific context before deciding which engineers should enter a deeper technical conversation.
        </p>
      </div>
    </div>

    <div class="grid gap-6">
      <div class="card p-6 md:p-8">
        <h2 class="text-2xl font-black">Skills to filter for</h2>
        <div class="mt-5 flex flex-wrap gap-3">
          {role.skills.map((skill) => (
            <span class="rounded-full border border-[var(--line)] bg-[var(--surface-2)] px-4 py-2 text-sm font-bold text-[var(--text)]">{skill}</span>
          ))}
        </div>
      </div>

      <div class="card p-6 md:p-8">
        <h2 class="text-2xl font-black">tenX verification badges</h2>
        <div class="mt-5 flex flex-wrap gap-3">
          {role.badges.map((badge) => (
            <span class="rounded-full border border-[var(--accent)] bg-[color-mix(in_srgb,var(--accent)_12%,transparent)] px-4 py-2 text-sm font-bold text-[var(--text)]">{badge}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container grid gap-8 pb-16 lg:grid-cols-[1fr_0.78fr] lg:pb-24">
    <div class="panel p-6 md:p-8">
      <p class="eyebrow">FAQ</p>
      <h2 class="mt-3 text-3xl font-black">Hiring {role.shortTitle} in {city.name}</h2>
      <div class="mt-6 grid gap-5">
        {faqs.map((faq) => (
          <details class="card p-5" open>
            <summary class="cursor-pointer text-lg font-black">{faq.question}</summary>
            <p class="mt-3 leading-7 text-[var(--muted)]">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <aside class="card p-6 md:p-8">
      <p class="eyebrow">Next steps</p>
      <h2 class="mt-3 text-2xl font-black">Compare talent before you interview.</h2>
      <p class="mt-4 leading-7 text-[var(--muted)]">
        Review how tenX verifies candidates, browse the network, check published pricing, or send engineers to the candidate application flow if they should join the launch pool.
      </p>
      <div class="mt-6 grid gap-3">
        <a class="button button-secondary" href="/how-it-works">How it works</a>
        <a class="button button-secondary" href="/network">Network</a>
        <a class="button button-secondary" href="/pricing">Pricing</a>
        <a class="button button-secondary" href="/apply">Apply as an engineer</a>
      </div>
    </aside>
  </section>
</BaseLayout>
