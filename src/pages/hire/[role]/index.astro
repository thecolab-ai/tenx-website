---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { href } from "../../../lib/href";
import { collectionPageSchema } from "../../../lib/seo";
import { allCities, allRoles, type City, type Role } from "../../../lib/data";

type Props = {
  role: Role;
};

export function getStaticPaths() {
  return allRoles.map((role) => ({
    params: { role: role.slug },
    props: { role }
  }));
}

const { role } = Astro.props;
const path = `/hire/${role.slug}`;
const nzCities = allCities.filter((city) => city.countryCode === "NZ");
const auCities = allCities.filter((city) => city.countryCode === "AU");
const title = `Hire ${role.title} by city | tenX`;
const description = `Hire AI-verified ${role.shortTitle} across New Zealand and Australia. Compare open NZ markets, June 2026 AUS expansion cities, skills, badges, and tenX verification signals.`;
const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Hire", path: "/hire" },
  { name: role.title, path }
];

function cityPath(city: City): string {
  return `/hire/${role.slug}/${city.slug}`;
}
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  breadcrumbs={breadcrumbs}
  schema={collectionPageSchema({
    title: `Hire ${role.title} in New Zealand and Australia`,
    description,
    path
  })}
>
  <section class="container py-12 md:py-16">
    <nav class="mono flex flex-wrap items-center gap-2 text-xs text-[var(--faint)]" aria-label="Breadcrumb">
      <a class="hover:text-[var(--text)]" href={href("/")}>Home</a>
      <span>/</span>
      <a class="hover:text-[var(--text)]" href={href("/hire")}>Hire</a>
      <span>/</span>
      <span class="text-[var(--muted)]">{role.title}</span>
    </nav>

    <div class="mt-8 grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div>
        <p class="eyebrow">Programmatic city hiring</p>
        <h1 class="mt-4 text-5xl font-black leading-tight md:text-6xl">Hire {role.title} — New Zealand and Australia cities</h1>
        <p class="mt-6 text-xl leading-8 text-[var(--muted)]">
          {role.summary} tenX keeps the city pages focused on verified AI delivery evidence, market salary guidance, and local candidate availability so employers can compare where to source {role.shortTitle}.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button button-primary" href={href("/hire")}>All roles</a>
          <a class="button button-secondary" href={href("/how-it-works")}>How verification works</a>
          <a class="button button-secondary" href={href("/network")}>Network</a>
        </div>
      </div>

      <aside class="panel p-6 md:p-8">
        <p class="eyebrow">Role signals</p>
        <h2 class="mt-3 text-2xl font-black">Filter by skills and tenX badges.</h2>
        <p class="mt-4 leading-7 text-[var(--muted)]">
          Each city page combines this role profile with local market context, salary multipliers, and employer availability. Use the links below to inspect the best-fit city page before posting a role.
        </p>
        <div class="mt-6">
          <h3 class="mono text-sm font-bold text-[var(--text)]">Core skills</h3>
          <div class="mt-3 flex flex-wrap gap-3">
            {role.skills.map((skill) => (
              <span class="rounded-full border border-[var(--line)] bg-[var(--surface-2)] px-4 py-2 text-sm font-bold text-[var(--text)]">{skill}</span>
            ))}
          </div>
        </div>
        <div class="mt-6">
          <h3 class="mono text-sm font-bold text-[var(--text)]">Platform badges</h3>
          <div class="mt-3 flex flex-wrap gap-3">
            {role.badges.map((badge) => (
              <span class="rounded-full border border-[var(--accent)] bg-[color-mix(in_srgb,var(--accent)_12%,transparent)] px-4 py-2 text-sm font-bold text-[var(--text)]">{badge}</span>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="container grid gap-8 pb-16 lg:grid-cols-2 lg:pb-24">
    <div class="panel p-6 md:p-8">
      <p class="eyebrow">Open NZ cities</p>
      <h2 class="mt-3 text-3xl font-black">Employer access markets</h2>
      <div class="mt-6 grid gap-4">
        {nzCities.map((city) => (
          <a class="card block p-5 transition hover:border-[var(--accent)]" href={href(cityPath(city))}>
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h3 class="text-xl font-black">{city.name}</h3>
              <span class="mono rounded-full border border-[var(--line)] px-3 py-1 text-xs text-[var(--muted)]">Open now</span>
            </div>
            <p class="mt-3 leading-7 text-[var(--muted)]">{city.marketNote}</p>
            <p class="mono mt-4 text-sm text-[var(--faint)]">{city.talentCount} engineers in this discipline</p>
          </a>
        ))}
      </div>
    </div>

    <div class="panel p-6 md:p-8">
      <p class="eyebrow">AUS expansion</p>
      <h2 class="mt-3 text-3xl font-black">Coming-soon cities</h2>
      <div class="mt-6 grid gap-4">
        {auCities.map((city) => (
          <a class="card block p-5 transition hover:border-[var(--accent)]" href={href(cityPath(city))}>
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h3 class="text-xl font-black">{city.name}</h3>
              <span class="mono rounded-full border border-[var(--accent)] bg-[color-mix(in_srgb,var(--accent)_12%,transparent)] px-3 py-1 text-xs text-[var(--text)]">June 2026</span>
            </div>
            <p class="mt-3 leading-7 text-[var(--muted)]">{city.marketNote}</p>
            <p class="mono mt-4 text-sm text-[var(--faint)]">{city.talentCount} engineers in this discipline</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
