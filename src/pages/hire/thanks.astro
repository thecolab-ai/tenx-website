---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Employer waitlist joined"
  description="Your tenX employer waitlist request has been received."
  path="/hire/thanks"
  breadcrumbs={[{ name: "Home", path: "/" }, { name: "Hire", path: "/hire" }, { name: "Thanks", path: "/hire/thanks" }]}
>
  <section class="container section">
    <div class="panel max-w-3xl p-8 md:p-10">
      <p class="eyebrow">Waitlist joined</p>
      <h1 class="mt-4 text-5xl font-black leading-tight">Employer access opens in June 2026.</h1>
      <p class="mt-5 text-xl leading-8 text-[var(--muted)]">
        Your request is logged. Use the pricing and network pages to benchmark the model before the first employer wave opens.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="button button-primary" href="/pricing">View pricing</a>
        <a class="button button-secondary" href="/network">View network</a>
      </div>
    </div>
  </section>
</BaseLayout>
