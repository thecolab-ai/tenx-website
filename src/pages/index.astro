---
import BaseLayout from "../layouts/BaseLayout.astro";
import { href } from "../lib/href";
import { collectionPageSchema } from "../lib/seo";
import { allRoles } from "../lib/data";

const stats = [
  { value: "100", label: "AI-VERIFIED ENGINEERS AT LAUNCH" },
  { value: "10%", label: "PERMANENT PLACEMENT FEE" },
  { value: "20%", label: "CONTRACTOR LOADING" },
  { value: "June", label: "EMPLOYER ACCESS OPENS" }
];

const badges = [
  "Claude fluency",
  "OpenAI fluency",
  "Google fluency",
  "Prompt design",
  "RAG",
  "Agent design",
  "Evals",
  "MLOps",
  "Code-with-AI"
];

const valueProps = [
  {
    eyebrow: "// 01 — VETTING",
    title: "Verification happens in the platform",
    body: "Engineers earn badges through practical skills assessments. Employers see what they passed, what it proves, and where they fit."
  },
  {
    eyebrow: "// 02 — AI TOOLS",
    title: "Ship faster. Choose the right tool.",
    body: "Claude, OpenAI, and Google all behave differently. tenX connects you with engineers who compare options and deliver production-ready work."
  },
  {
    eyebrow: "// 03 — PRICING",
    title: "Published fees from day one",
    body: "Permanent placements are 10% of first-year salary. Contractors carry a 20% loading on monthly billings. No hidden spread."
  }
];

const modelChips = ["Claude", "OpenAI", "Google"];
---

<BaseLayout
  title="Ship faster with AI-verified engineers. Fluent across Claude, OpenAI, Google."
  description="tenX multiplies your team's output. AI-verified engineers across Claude, OpenAI, Google. Published fees. Hired in days."
  path="/"
  schema={collectionPageSchema({
    title: "tenX AI engineering network",
    description: "AI-verified engineers across Claude, OpenAI, Google, RAG, agents, evals, MLOps, and code-with-AI.",
    path: "/"
  })}
>
  <!-- HERO — dense type, flat background, left-aligned, no illustration -->
  <section class="hero-section">
    <div class="container">
      <p class="eyebrow hero-eyebrow">// AI-VERIFIED ENGINEERING TALENT</p>

      <h1 class="hero-h1">
        10x your team's output.<br />
        <span class="hero-h1-secondary">Verified engineers, fluent across Claude, OpenAI, Google.</span>
      </h1>

      <p class="hero-subline">
        Amplify what your best people do. Every engineer passes practical skills assessments before they reach you. Published fees. Hired in days.
      </p>

      <div class="hero-cta-row">
        <a class="button button-primary hero-cta-primary" href={href("/hire")}>Hire engineers</a>
        <a class="button button-secondary" href={href("/apply")}>Apply as an engineer &rarr;</a>
      </div>

      <p class="hero-trust">// 10% perm &middot; 20% contractor &middot; <a href={href("/pricing")} class="hero-trust-link">pricing on page</a></p>

      <div class="hero-chips">
        {modelChips.map((chip) => (
          <span class="model-chip">{chip}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS — clean horizontal rule with numbers -->
  <section class="section section-border">
    <div class="container">
      <div class="stats-grid">
        {stats.map((stat) => (
          <div class="stat-block">
            <p class="eyebrow">{stat.label}</p>
            <p class="stat-value" style="margin-top: 0.5rem;">{stat.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROPS — what changes when you hire through tenX -->
  <section class="section section-border-top">
    <div class="container">
      <p class="eyebrow">// WHAT CHANGES</p>
      <h2 class="section-h2" style="margin-top: 1rem; max-width: 36rem;">
        Ship faster. Know what you're paying before the first call.
      </h2>
      <div class="value-grid" style="margin-top: 2.5rem;">
        {valueProps.map((item) => (
          <article class="card">
            <p class="eyebrow">{item.eyebrow}</p>
            <h3 class="value-title">{item.title}</h3>
            <p class="value-body">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BADGE MATRIX -->
  <section class="section section-border-top">
    <div class="container">
      <p class="eyebrow">// VERIFICATION MATRIX</p>
      <h2 class="section-h2" style="margin-top: 1rem;">Badges earned for practical AI work.</h2>
      <div class="badge-grid" style="margin-top: 2.5rem;">
        {badges.map((badge, index) => (
          <div class="card">
            <p class="eyebrow">badge.{String(index + 1).padStart(2, "0")}</p>
            <p class="badge-label">{badge}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ROLES BROWSE -->
  <section class="section section-border-top">
    <div class="container">
      <p class="eyebrow">// HIRE BY ROLE</p>
      <h2 class="section-h2" style="margin-top: 1rem;">Get the output you need, not just a hire.</h2>
      <div class="roles-grid" style="margin-top: 2.5rem;">
        {allRoles.map((role) => (
          <a class="card roles-card" href={href(`/hire/${role.slug}`)}>
            <p class="eyebrow">{role.slug}</p>
            <h3 class="value-title">{role.title}</h3>
            <p class="value-body">{role.summary}</p>
            <p class="roles-link">&rarr; Hire {role.shortTitle}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CANDIDATE-FIRST LAUNCH -->
  <section class="section section-border">
    <div class="container">
      <div class="launch-grid">
        <div>
          <p class="eyebrow">// CANDIDATE-FIRST LAUNCH</p>
          <h2 class="section-h2" style="margin-top: 1rem;">Phase 1 is for engineers.</h2>
          <p class="launch-body">
            Engineers apply, complete practical tests, earn badges, and increase match priority before employer access opens.
            That gives the June employer launch a verified network, not an empty marketplace.
          </p>
        </div>
        <div class="steps-list">
          {["Apply with your profile", "Take a practical test", "Earn skill and provider badges", "Get matched as employer demand opens"].map((step, index) => (
            <div class="card step-card">
              <span class="mono step-num" style="color: var(--accent);">0{index + 1}</span>
              <span class="step-text">{step}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- DUAL CTA -->
  <section class="section">
    <div class="container cta-grid">
      <div class="panel" style="padding: 2rem;">
        <p class="eyebrow">// FOR ENGINEERS</p>
        <h2 class="section-h2" style="margin-top: 1rem; font-size: 1.75rem;">Prove the work once. Reuse the signal.</h2>
        <p class="value-body">
          Apply now, then complete the skills assessment at app.tenxtalent.ai. More verified badges mean higher match priority.
        </p>
        <a class="button button-primary" href={href("/apply")} style="margin-top: 1.5rem; display: inline-flex;">Apply as an engineer</a>
      </div>
      <div class="panel" style="padding: 2rem;">
        <p class="eyebrow">// FOR EMPLOYERS</p>
        <h2 class="section-h2" style="margin-top: 1rem; font-size: 1.75rem;">Transparent pricing before the first call.</h2>
        <p class="value-body">
          Join the waitlist for June 2026. The network opens with 100 AI-verified engineers and published fees.
        </p>
        <div style="margin-top: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.75rem;">
          <a class="button button-secondary" href={href("/hire")}>Join employer waitlist</a>
          <a class="button button-secondary" href={href("/pricing")}>View pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────── */

  .hero-section {
    padding-top: 5rem;
    padding-bottom: 5.5rem;
    background: var(--bg-base);
    border-bottom: 1px solid var(--border-subtle);
  }

  @media (min-width: 1024px) {
    .hero-section {
      padding-top: 9rem;
      padding-bottom: 9rem;
    }
  }

  /* Pulsing status dot — subtle, stops on reduced-motion */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-eyebrow::before {
    content: "";
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: dot-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow::before {
      animation: none;
    }
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  /* Display H1 — weight 500, not bold, tight tracking */
  .hero-h1 {
    font-family: "Inter Display", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-feature-settings: "ss01", "cv11", "ss03";
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.04;
    margin-top: 1.5rem;
    color: var(--text-primary);
    max-width: 22ch;
  }

  /* Second line — secondary colour, slightly smaller, same tracking */
  .hero-h1-secondary {
    color: var(--text-secondary);
    font-size: 0.78em;
    letter-spacing: -0.02em;
    line-height: 1.12;
    display: block;
    margin-top: 0.3em;
  }

  .hero-subline {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-top: 1.75rem;
    max-width: 56ch;
  }

  @media (min-width: 768px) {
    .hero-subline {
      font-size: 1.125rem;
    }
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.25rem;
  }

  .hero-cta-primary {
    min-height: 44px;
    padding: 11px 22px;
    font-size: 0.9375rem;
  }

  .hero-trust {
    font-family: "JetBrains Mono", "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 1.5rem;
  }

  .hero-trust-link {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    transition: color 120ms;
  }

  .hero-trust-link:hover {
    color: var(--text-secondary);
  }

  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  /* ── Section borders ──────────────────────────────── */

  .section-border {
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-border-top {
    border-top: 1px solid var(--border-subtle);
  }

  /* ── Stats ────────────────────────────────────────── */

  .stats-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-block {
    display: flex;
    flex-direction: column;
  }

  /* ── Badge grid ───────────────────────────────────── */

  .badge-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 640px) {
    .badge-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .badge-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .badge-label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-top: 0.75rem;
  }

  /* ── Section headings — weight 500 ───────────────── */

  .section-h2 {
    font-family: "Inter Display", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-feature-settings: "ss01", "cv11", "ss03";
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--text-primary);
  }

  @media (min-width: 1024px) {
    .section-h2 {
      font-size: 2.5rem;
    }
  }

  /* ── Value props grid ─────────────────────────────── */

  .value-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .value-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .value-title {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-top: 0.75rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .value-body {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-top: 0.75rem;
  }

  /* ── Roles browse grid ────────────────────────────── */

  .roles-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .roles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .roles-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .roles-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: border-color 120ms;
  }

  .roles-card:hover {
    border-color: var(--border-default);
  }

  .roles-link {
    color: var(--accent);
    font-size: 0.875rem;
    font-weight: 500;
    margin-top: auto;
    padding-top: 1rem;
  }

  /* ── Launch section ───────────────────────────────── */

  .launch-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .launch-grid {
      grid-template-columns: 0.8fr 1.2fr;
      align-items: start;
    }
  }

  .launch-body {
    margin-top: 1.25rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 40ch;
    font-size: 0.9375rem;
  }

  .steps-list {
    display: grid;
    gap: 0.75rem;
  }

  .step-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem !important;
  }

  .step-num {
    font-family: "JetBrains Mono", "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.875rem;
    flex-shrink: 0;
    width: 2rem;
  }

  .step-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  /* ── Dual CTA ─────────────────────────────────────── */

  .cta-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .cta-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
