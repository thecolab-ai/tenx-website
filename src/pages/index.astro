---
import BaseLayout from "../layouts/BaseLayout.astro";
import { href } from "../lib/href";
import { collectionPageSchema } from "../lib/seo";

const stats = [
  { value: "100", label: "AI-VERIFIED ENGINEERS AT LAUNCH" },
  { value: "10%", label: "PERMANENT PLACEMENT FEE" },
  { value: "20%", label: "CONTRACTOR LOADING" },
  { value: "0", label: "FOUNDER CALLS REQUIRED" }
];

const badges = [
  "Claude fluency",
  "OpenAI fluency",
  "Google fluency",
  "Prompt engineering",
  "RAG",
  "Agent design",
  "Evals",
  "MLOps",
  "Code-with-AI"
];

const valueProps = [
  {
    eyebrow: "// 01 — VETTING",
    title: "Verification happens in the platform",
    body: "Engineers earn badges through self-service sandboxes. The signal is observable work, not a warm intro or a founder gut check."
  },
  {
    eyebrow: "// 02 — MODEL FLUENCY",
    title: "Model fluency, not model religion",
    body: "Claude, OpenAI, and Google all have different failure modes. tenX ranks engineers who can choose, compare, and ship across them."
  },
  {
    eyebrow: "// 03 — PRICING",
    title: "Published margins from day one",
    body: "Permanent placements are 10% of first-year salary. Contractors carry a 20% loading on monthly billings. No hidden spread."
  }
];

const modelChips = ["Claude", "OpenAI", "Google"];
---

<BaseLayout
  title="AI-verified engineers. Fluent across Claude, OpenAI, Google."
  description="tenX is the NZ-first AI engineering network. Platform-verified engineers, published margins, and hiring in days."
  path="/"
  schema={collectionPageSchema({
    title: "tenX AI engineering network",
    description: "AI-verified engineers across Claude, OpenAI, Google, RAG, agents, evals, MLOps, and code-with-AI.",
    path: "/"
  })}
>
  <!-- HERO — dense type on flat background, no illustration -->
  <section class="hero-section">
    <div class="container">
      <p class="eyebrow">// AI-VERIFIED ENGINEERING TALENT</p>

      <h1 class="hero-h1">
        AI-verified engineers.<br />
        Fluent across Claude, OpenAI, Google.<br />
        Hired in days.
      </h1>

      <p class="hero-subline">
        Every engineer is platform-verified through skill sandboxes. No founder gatekeeping. No 50% margins.
      </p>

      <div class="hero-cta-row">
        <a class="button button-primary" href={href("/apply")}>Apply as an engineer</a>
        <a class="button button-secondary" href={href("/hire")}>Hire engineers &rarr;</a>
      </div>

      <p class="hero-trust">// 10% perm &middot; 20% contractor &middot; pricing on page</p>

      <div class="hero-chips">
        {modelChips.map((chip) => (
          <span class="model-chip">{chip}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS — 128px below hero, per section rhythm -->
  <section class="section section-border">
    <div class="container">
      <div class="stats-grid">
        {stats.map((stat) => (
          <div class="stat-block">
            <p class="eyebrow">{stat.label}</p>
            <p class="stat-value" style="margin-top: 0.5rem;">{stat.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BADGE MATRIX — moved below hero -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">// VERIFICATION MATRIX</p>
      <h2 class="section-h2" style="margin-top: 1rem;">Badges earned per stack and per model.</h2>
      <div class="badge-grid" style="margin-top: 2.5rem;">
        {badges.map((badge, index) => (
          <div class="card">
            <p class="eyebrow">badge.{String(index + 1).padStart(2, "0")}</p>
            <p class="badge-label">{badge}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROPS -->
  <section class="section section-border-top">
    <div class="container">
      <p class="eyebrow">// WHAT CHANGES</p>
      <h2 class="section-h2" style="margin-top: 1rem; max-width: 42rem;">
        Hiring AI talent should feel like reading a benchmark, not decoding a marketplace.
      </h2>
      <div class="value-grid" style="margin-top: 2.5rem;">
        {valueProps.map((item) => (
          <article class="card">
            <p class="eyebrow">{item.eyebrow}</p>
            <h3 class="value-title">{item.title}</h3>
            <p class="value-body">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CANDIDATE-FIRST LAUNCH -->
  <section class="section section-border">
    <div class="container">
      <div class="launch-grid">
        <div>
          <p class="eyebrow">// CANDIDATE-FIRST LAUNCH</p>
          <h2 class="section-h2" style="margin-top: 1rem;">Phase 1 is for engineers.</h2>
          <p class="launch-body">
            Engineers apply, complete sandbox tests, earn badges, and increase match priority before employer access opens.
            That gives the June employer launch a verified network, not an empty marketplace.
          </p>
        </div>
        <div class="steps-list">
          {["Apply with your profile", "Take a sandbox test", "Earn badges by stack and model", "Get matched as employer demand opens"].map((step, index) => (
            <div class="card step-card">
              <span class="mono step-num" style="color: var(--accent);">0{index + 1}</span>
              <span class="step-text">{step}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- DUAL CTA -->
  <section class="section">
    <div class="container cta-grid">
      <div class="panel" style="padding: 2rem;">
        <p class="eyebrow">// FOR ENGINEERS</p>
        <h2 class="section-h2" style="margin-top: 1rem; font-size: 1.75rem;">Prove the work once. Reuse the signal.</h2>
        <p class="value-body">
          Apply now, then complete the sandbox flow at app.tenxtalent.ai. More verified badges mean higher match priority.
        </p>
        <a class="button button-primary" href={href("/apply")} style="margin-top: 1.5rem; display: inline-flex;">Apply as an engineer</a>
      </div>
      <div class="panel" style="padding: 2rem;">
        <p class="eyebrow">// FOR EMPLOYERS</p>
        <h2 class="section-h2" style="margin-top: 1rem; font-size: 1.75rem;">Transparent pricing before the first call.</h2>
        <p class="value-body">
          Join the waitlist for June 2026. The network opens with 100 AI-verified engineers and published margins.
        </p>
        <div style="margin-top: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.75rem;">
          <a class="button button-secondary" href={href("/hire")}>Join employer waitlist</a>
          <a class="button button-secondary" href={href("/pricing")}>View pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero — flat background, 128px top padding desktop */
  .hero-section {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background: var(--bg-base);
  }

  @media (min-width: 1024px) {
    .hero-section {
      padding-top: 8rem;
      padding-bottom: 8rem;
    }
  }

  /* Display H1 — weight 500, not bold */
  .hero-h1 {
    font-family: "Inter Display", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-feature-settings: "ss01", "cv11", "ss03";
    font-size: 2.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-top: 1.25rem;
    color: var(--text-primary);
    max-width: 22ch;
  }

  @media (min-width: 1024px) {
    .hero-h1 {
      font-size: 4.5rem;
    }
  }

  .hero-subline {
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin-top: 1.5rem;
    max-width: 60ch;
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hero-trust {
    font-family: "JetBrains Mono", "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 1.25rem;
  }

  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  /* Section borders */
  .section-border {
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-border-top {
    border-top: 1px solid var(--border-subtle);
  }

  /* Stats */
  .stats-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-block {
    display: flex;
    flex-direction: column;
  }

  /* Badge grid */
  .badge-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 640px) {
    .badge-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .badge-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .badge-label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-top: 0.75rem;
  }

  /* Section headings — weight 500 */
  .section-h2 {
    font-family: "Inter Display", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-feature-settings: "ss01", "cv11", "ss03";
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--text-primary);
  }

  @media (min-width: 1024px) {
    .section-h2 {
      font-size: 2.5rem;
    }
  }

  /* Value props */
  .value-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .value-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .value-title {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-top: 0.75rem;
    letter-spacing: -0.01em;
  }

  .value-body {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-top: 0.75rem;
  }

  /* Launch section */
  .launch-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .launch-grid {
      grid-template-columns: 0.8fr 1.2fr;
      align-items: start;
    }
  }

  .launch-body {
    margin-top: 1.25rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 40ch;
    font-size: 0.9375rem;
  }

  .steps-list {
    display: grid;
    gap: 0.75rem;
  }

  .step-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem !important;
  }

  .step-num {
    font-family: "JetBrains Mono", "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.875rem;
    flex-shrink: 0;
    width: 2rem;
  }

  .step-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  /* Dual CTA */
  .cta-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .cta-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
