---
import BaseLayout from "../layouts/BaseLayout.astro";
import { collectionPageSchema } from "../lib/seo";

const stats = [
  { value: "100", label: "AI-verified engineers at launch" },
  { value: "10%", label: "permanent placement fee" },
  { value: "20%", label: "contractor loading" },
  { value: "0", label: "founder calls required to verify skill" }
];

const badges = [
  "Claude fluency",
  "GPT fluency",
  "Gemini fluency",
  "Prompt engineering",
  "RAG",
  "Agent design",
  "Evals",
  "MLOps",
  "Code-with-AI"
];

const valueProps = [
  {
    title: "Verification happens in the platform",
    body: "Engineers earn badges through self-service sandboxes. The signal is observable work, not a warm intro or a founder gut check."
  },
  {
    title: "Model fluency, not model religion",
    body: "Claude, GPT, and Gemini all have different failure modes. tenX ranks engineers who can choose, compare, and ship across them."
  },
  {
    title: "Published margins from day one",
    body: "Permanent placements are 10% of first-year salary. Contractors carry a 20% loading on monthly billings. No hidden spread."
  }
];
---

<BaseLayout
  title="AI-verified engineers. Fluent across Claude, GPT, Gemini."
  description="tenX is the NZ-first AI engineering network. Platform-verified engineers, published margins, and hiring in days."
  path="/"
  schema={collectionPageSchema({
    title: "tenX AI engineering network",
    description: "AI-verified engineers across Claude, GPT, Gemini, RAG, agents, evals, MLOps, and code-with-AI.",
    path: "/"
  })}
>
  <section class="container grid gap-12 pb-16 pt-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:pb-20 lg:pt-24">
    <div>
      <p class="eyebrow">NZ-first AI engineering network</p>
      <h1 class="mt-5 max-w-5xl text-5xl font-black leading-[0.96] md:text-7xl">
        AI-verified engineers. Fluent across Claude, GPT, Gemini. Hired in days.
      </h1>
      <p class="mt-6 max-w-2xl text-xl leading-8 text-[var(--muted)]">
        Every engineer is platform-verified through skill sandboxes. No founder gatekeeping. No 50% margins.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="button button-primary" href="/apply">Apply as an engineer</a>
        <a class="button button-secondary" href="/hire">Hire engineers</a>
      </div>
      <p class="mono mt-5 text-sm text-[var(--faint)]">
        Candidate intake is open now. Employer access opens in June 2026.
      </p>
    </div>
    <div class="panel p-4">
      <div class="grid gap-3">
        <div class="flex items-center justify-between border-b border-[var(--line)] pb-3">
          <span class="mono text-sm text-[var(--muted)]">verification matrix</span>
          <span class="mono text-sm text-[var(--accent)]">updated monthly</span>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          {badges.map((badge, index) => (
            <div class="card min-h-24 p-4">
              <p class="mono text-xs text-[var(--faint)]">badge.{String(index + 1).padStart(2, "0")}</p>
              <p class="mt-3 text-sm font-bold leading-5">{badge}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-[var(--line)] bg-[var(--bg-2)]">
    <div class="container grid gap-6 py-8 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat) => (
        <div>
          <p class="stat-value">{stat.value}</p>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow">What changes</p>
        <h2 class="mt-4 text-4xl font-black leading-tight md:text-5xl">
          Hiring AI talent should feel like reading a benchmark, not decoding a marketplace.
        </h2>
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {valueProps.map((item) => (
          <article class="card p-6">
            <h3 class="text-xl font-black">{item.title}</h3>
            <p class="mt-4 leading-7 text-[var(--muted)]">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section border-y border-[var(--line)] bg-[var(--bg-2)]">
    <div class="container grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <p class="eyebrow">Candidate-first launch</p>
        <h2 class="mt-4 text-4xl font-black leading-tight">Phase 1 is for engineers.</h2>
        <p class="mt-5 leading-8 text-[var(--muted)]">
          Engineers apply, complete sandbox tests, earn badges, and increase match priority before employer access opens.
          That gives the June employer launch a verified network, not an empty marketplace.
        </p>
      </div>
      <div class="grid gap-3">
        {["Apply with your profile", "Take a sandbox test", "Earn badges by stack and model", "Get matched as employer demand opens"].map((step, index) => (
          <div class="card flex items-center gap-4 p-5">
            <span class="mono grid size-10 shrink-0 place-items-center rounded border border-[var(--line)] text-[var(--accent)]">
              {index + 1}
            </span>
            <span class="font-bold">{step}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid gap-6 lg:grid-cols-2">
      <div class="panel p-8">
        <p class="eyebrow">For engineers</p>
        <h2 class="mt-4 text-3xl font-black">Prove the work once. Reuse the signal.</h2>
        <p class="mt-4 leading-7 text-[var(--muted)]">
          Apply now, then complete the sandbox flow at app.tenxtalent.ai. More verified badges mean higher match priority.
        </p>
        <a class="button button-primary mt-6" href="/apply">Apply as an engineer</a>
      </div>
      <div class="panel p-8">
        <p class="eyebrow">For employers</p>
        <h2 class="mt-4 text-3xl font-black">Transparent pricing before the first call.</h2>
        <p class="mt-4 leading-7 text-[var(--muted)]">
          Join the waitlist for June 2026. The network opens with 100 AI-verified engineers and published margins.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a class="button button-secondary" href="/hire">Join employer waitlist</a>
          <a class="button button-secondary" href="/pricing">View pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
