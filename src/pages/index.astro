---
import BaseLayout from "../layouts/BaseLayout.astro";
import TenX from "../components/TenX.astro";
import { href } from "../lib/href";
import { collectionPageSchema } from "../lib/seo";

const badges = [
  { code: "RAG",    name: "RAG",            desc: "Retrieval, reranking, grounded answers.",          count: 38 },
  { code: "CLAUDE", name: "Claude fluency", desc: "Tool-use suite, long-context, system prompts.",    count: 77 },
  { code: "OPENAI", name: "OpenAI fluency", desc: "Function-calling, structured output, streaming.",  count: 84 },
  { code: "GOOGLE", name: "Google fluency", desc: "Gemini, Vertex, structured output, grounding.",    count: 49 },
  { code: "AGENT",  name: "Agent loops",    desc: "Plans, retries, sub-tasks, deterministic eval.",   count: 31 },
  { code: "EVALS",  name: "Evals",          desc: "Harnesses, golden sets, regression guards.",       count: 42 },
  { code: "MLOPS",  name: "MLOps",          desc: "Cold-start, autoscale, drift, observability.",     count: 26 },
  { code: "CODE",   name: "Code-with-AI",   desc: "Diff review, codegen pipelines, repo grounding.",  count: 35 },
  { code: "RERANK", name: "Reranker",       desc: "Latency-bound rerank, hybrid search, BM25+vec.",   count: 19 },
];

const steps = [
  { num: "01", title: "Brief",     body: "30-minute call. We translate the outcome into a rubric your team can sign off.",    tag: "Day 0" },
  { num: "02", title: "Shortlist", body: "Three or four matched multipliers, each with the evals you'd score them against.", tag: "Day 2" },
  { num: "03", title: "Trial",     body: "Two-week scoped trial, eval gate at the end. No fee if we don't clear it.",        tag: "Week 1" },
  { num: "04", title: "Ship",      body: "Multiplier in seat. Public eval cadence, fortnightly check-in. Replace anytime.",  tag: "Week 3+" },
];

const tickerItems = [
  { v: "6 stages",      l: "screening · public" },
  { v: "v2.4",          l: "rubric · versioned" },
  { v: "openai",        l: "fluency · claimed" },
  { v: "claude",        l: "fluency · claimed" },
  { v: "google",        l: "fluency · claimed" },
  { v: "10%",           l: "perm placement fee" },
  { v: "20%",           l: "contractor loading" },
  { v: "June",          l: "employer access" },
  { v: "AKL · WLG · SYD", l: "live regions" },
  { v: "cohort 02",     l: "screening open" },
];

const journeyStages = [
  { label: "ship-log received",   when: "00:00:12" },
  { label: "skills extracted",    when: "00:02:48" },
  { label: "eval harness running",when: "00:11:47" },
  { label: "council review",      when: "00:48:09" },
  { label: "craft interview",     when: "02:11:00" },
  { label: "matched to brief",    when: "08:14:22" },
];
---

<BaseLayout
  title="Buy the multiplier. Not the seat. | tenX"
  description="tenX gives your team direct access to the outputs a 10x operator produces. AI-verified multipliers screened across a public rubric. 10% perm, 20% contractor. Opens June 2026."
  path="/"
  schema={collectionPageSchema({
    title: "tenX, the AI multiplier network",
    description: "AI-verified multipliers across Claude, OpenAI, Google. Public rubric. Published fees. Hired in days.",
    path: "/"
  })}
>

  <!-- ══ HERO ══════════════════════════════════════════════ -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-pre">
        <span class="pulse-dot" aria-hidden="true"></span>
        <span class="hero-pre-text"><TenX /> &middot; the AI multiplier network &middot; cohort 02 screening</span>
      </div>
      <div class="hero-grid">
        <!-- Left: Headline + CTAs -->
        <div class="hero-left">
          <h1 class="hero-h1">
            <span class="h1-row">Buy the</span>
            <span class="h1-row">multiplier.</span>
            <span class="h1-row">Not the<span class="h1-x">seat</span>.</span>
          </h1>
          <p class="hero-sub">
            <TenX /> gives your team direct access to the outputs a 10x operator produces:
            shipped features, decisions made, hours back. Every multiplier walks the same
            six-stage screening you'll read before you buy.
          </p>
          <div class="hero-cta-row">
            <a class="button button-primary hero-cta-primary" href={href("/hire")}>
              Buy access
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <a class="button button-secondary" href={href("/network")}>See what gets shipped</a>
          </div>
          <div class="hero-meta">
            <span class="hm-item"><span class="hm-k">Screening</span><span class="hm-v">6 stages &middot; public rubric</span></span>
            <span class="hm-item"><span class="hm-k">Perm fee</span><span class="hm-v">10%</span></span>
            <span class="hm-item"><span class="hm-k">Contractor</span><span class="hm-v">20% loading</span></span>
            <span class="hm-item"><span class="hm-k">Opens</span><span class="hm-v">June 2026</span></span>
          </div>
        </div>

        <!-- Right: Screening journey panel -->
        <div class="hero-right">
          <div class="journey" id="journey-panel" aria-label="Live screening journey simulation">
            <div class="journey-head">
              <span class="mac-dots" aria-hidden="true"><i></i><i></i><i></i></span>
              <span><span class="head-id">applicant &middot; ENG-pending</span> &middot; cohort 02 screening</span>
              <span class="pulse-dot" aria-hidden="true"></span>
            </div>
            <div class="journey-stages" id="journey-stages">
              {journeyStages.map((s, i) => (
                <div class={`journey-stage js-${i < 2 ? 'done' : i === 2 ? 'active' : 'future'}`} data-idx={i}>
                  <span class="j-marker"></span>
                  <span class="j-label">{String(i + 1).padStart(2, "0")} &middot; {s.label}</span>
                  <span class="j-when">{s.when}</span>
                </div>
              ))}
            </div>
            <div class="journey-detail" id="journey-detail">
              <div class="journey-detail-row">
                <span class="dk">// case 12/14</span>
                <span class="dv">rag &middot; grounding 0.91</span>
                <span class="db">PASS</span>
              </div>
              <div class="journey-detail-row">
                <span class="dk">// case 13/14</span>
                <span class="dv">agent &middot; tool-use loop</span>
                <span class="db dim">RUN</span>
              </div>
              <div class="journey-progress" aria-hidden="true">
                <span class="jp-fill" id="journey-progress-fill" style="width: 86%"></span>
              </div>
            </div>
            <div class="journey-foot">
              <span>// rubric &middot; public &middot; v2.4</span>
              <span><span class="jf-stage" id="journey-stage-label">stage 3</span> of {journeyStages.length}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ TICKER ════════════════════════════════════════════ -->
  <div class="ticker-rail" aria-hidden="true">
    <div class="ticker-track">
      {[...tickerItems, ...tickerItems].map((it) => (
        <span class="ticker-item">
          <span class="dot" aria-hidden="true"></span>
          <span class="v">{it.v}</span>
          <span>&middot; {it.l}</span>
        </span>
      ))}
    </div>
  </div>

  <!-- ══ THESIS BENTO ═══════════════════════════════════════ -->
  <section class="section section-divider">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow" style="color: var(--accent);">// 01 &middot; the thesis</p>
          <h2 class="thesis-h2">Stop buying headcount. Start buying throughput.</h2>
        </div>
        <p class="sh-right">
          Every multiplier in the network publishes their score against a public,
          versioned rubric. You see what they ship, what they were graded on, and
          what they moved, not the seat, the output.
        </p>
      </div>

      <div class="bento">
        <!-- Screening stages - tall left cell -->
        <div class="bento-cell span-2 row-2">
          <p class="eyebrow">// screening</p>
          <div class="big-num" style="margin-top: 12px;">6</div>
          <p class="big-num-label">stages &middot; public &middot; rubric-led</p>
          <p style="font-size: 14px; line-height: 1.55; color: var(--text-secondary); margin-top: 20px;">
            Ship-log, skills extract, eval harness, council review, craft interview,
            match. Each stage has a written rubric, an artefact, and a public score,
            applicants and employers read the same receipt.
          </p>
        </div>
        <!-- Cohort ratio -->
        <div class="bento-cell span-2">
          <p class="eyebrow">// cohort intake</p>
          <div class="big-num paper" style="margin-top: 12px;">1<sup>:24</sup></div>
          <p class="big-num-label">applicants &middot; clearing the harness</p>
        </div>
        <!-- Perm fee -->
        <div class="bento-cell span-2">
          <p class="eyebrow">// permanent fee</p>
          <div class="big-num" style="margin-top: 12px;">10<sup>%</sup></div>
          <p class="big-num-label">flat &middot; no retainer &middot; published</p>
        </div>
        <!-- Fluency bars -->
        <div class="bento-cell span-3">
          <p class="eyebrow">// model fluency</p>
          <div style="margin-top: 16px; display: flex; flex-direction: column; gap: 2px;">
            <div class="bar-row">
              <span class="bar-label">OpenAI</span>
              <span class="bar-track"><span class="bar-fill" style="width: 84%"></span></span>
              <span class="bar-pct">84%</span>
            </div>
            <div class="bar-row">
              <span class="bar-label">Claude</span>
              <span class="bar-track"><span class="bar-fill" style="width: 77%"></span></span>
              <span class="bar-pct">77%</span>
            </div>
            <div class="bar-row">
              <span class="bar-label">Google</span>
              <span class="bar-track"><span class="bar-fill" style="width: 49%"></span></span>
              <span class="bar-pct">49%</span>
            </div>
          </div>
        </div>
        <!-- Pull quote -->
        <div class="bento-cell span-3">
          <p class="eyebrow">// pull quote</p>
          <p class="pull-quote" style="margin-top: 16px;">
            "Reading a <TenX /> profile is like reading a test report.
            We hired off the rubric, not the interview."
          </p>
          <p class="pull-cite">- Director of Engineering &middot; Series B, Auckland</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ BADGE CATALOGUE ════════════════════════════════════ -->
  <section class="section section-divider">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow" style="color: var(--accent);">// 02 &middot; the rubric</p>
          <h2 class="thesis-h2">Nine badges. Each one a public eval.</h2>
        </div>
        <p class="sh-right">
          Every badge has a written rubric, a held-out eval set, and a versioned
          score. Engineers earn badges; they don't claim them.
        </p>
      </div>
      <div class="badge-grid-9">
        {badges.map((b) => (
          <a class="badge-cell" href={href("/vetting")}>
            <div>
              <p class="bc-name">{b.name}</p>
              <p class="bc-desc">{b.desc}</p>
            </div>
            <div class="bc-meta">
              <span>// {b.code.toLowerCase()}</span>
              <span class="bc-count">{b.count} earned</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ PROCESS ════════════════════════════════════════════ -->
  <section class="section section-divider tight">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow" style="color: var(--accent);">// 03 &middot; how it works</p>
          <h2 class="thesis-h2">
            Brief on Monday. Multiplier on Wednesday.
            <em class="h2-dim"> Or the trial is free.</em>
          </h2>
        </div>
        <p class="sh-right">
          We sign the rubric before we send the shortlist. Trial gates on the
          same rubric we'd grade a permanent against.
        </p>
      </div>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-item">
            <p class="step-num">// {s.num}</p>
            <p class="step-title">{s.title}</p>
            <p class="step-body">{s.body}</p>
            <p class="step-tag">{s.tag}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ DUAL CTA ═══════════════════════════════════════════ -->
  <section class="section section-divider tight">
    <div class="container">
      <div class="cta-split">
        <div class="cta-left">
          <h2 class="thesis-h2">
            Buyer access opens <span style="color: var(--accent);">June 2026</span>.
          </h2>
          <p class="cta-body">
            We're taking briefs now. Hold a seat for your first piece of throughput,
            no fee, no retainer, no lock-in.
          </p>
        </div>
        <div class="cta-right">
          <a class="button button-primary" href={href("/hire")}>
            Hold a seat
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a class="button button-secondary" href={href("/apply")}>Join as a multiplier</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Journey panel animation script -->
<script>
  const STAGES = [
    {
      detail: [
        { k: "// parsing",    v: "2 repos · 11 commits",  b: "OK",    dim: false },
        { k: "// references", v: "4 contacts queued",      b: "OK",    dim: false },
      ],
      progress: 1,
    },
    {
      detail: [
        { k: "// claimed",    v: "rag · agent · claude",   b: "PARSED", dim: false },
        { k: "// rubric",     v: "3 badges queued",         b: "QUEUED", dim: true },
      ],
      progress: 1,
    },
    {
      detail: [
        { k: "// case 12/14", v: "rag · grounding 0.91",   b: "PASS", dim: false },
        { k: "// case 13/14", v: "agent · tool-use loop",  b: "RUN",  dim: true },
      ],
      progress: 0.86,
    },
    {
      detail: [
        { k: "// sign-off",   v: "retrieval · agent · 2/3",b: "PEND", dim: true },
        { k: "// rubric",     v: "public · v2.4 · versioned",b: "OK", dim: false },
      ],
      progress: 0.66,
    },
    {
      detail: [
        { k: "// scheduled",  v: "45m · founding engineer", b: "BOOK", dim: true },
        { k: "// topic",      v: "agent loop · retries",    b: "OK",   dim: false },
      ],
      progress: 0.5,
    },
    {
      detail: [
        { k: "// brief #042", v: "Series-B fintech · AKL",  b: "MATCH", dim: false },
        { k: "// trial gate", v: "rubric signed both sides", b: "OK",   dim: false },
      ],
      progress: 1,
    },
  ];

  let active = 2;

  function updateJourney() {
    const stageEls = document.querySelectorAll("#journey-stages .journey-stage");
    stageEls.forEach((el, i) => {
      el.className = "journey-stage " + (i < active ? "js-done" : i === active ? "js-active" : "");
    });

    const stage = STAGES[active];
    const rows = document.querySelectorAll("#journey-detail .journey-detail-row");
    stage.detail.forEach((d, i) => {
      if (!rows[i]) return;
      const kEl = rows[i].querySelector(".dk");
      const vEl = rows[i].querySelector(".dv");
      const bEl = rows[i].querySelector(".db");
      if (kEl) kEl.textContent = d.k;
      if (vEl) vEl.textContent = d.v;
      if (bEl) {
        bEl.textContent = d.b;
        bEl.className = "db" + (d.dim ? " dim" : "");
      }
    });

    const fill = document.getElementById("journey-progress-fill");
    if (fill) {
      fill.style.width = "0%";
      setTimeout(() => {
        if (fill) fill.style.width = (stage.progress * 100) + "%";
      }, 50);
    }

    const stageLabel = document.getElementById("journey-stage-label");
    if (stageLabel) stageLabel.textContent = "stage " + (active + 1);
  }

  // Advance every 4.2 seconds
  function advance() {
    active = (active + 1) % STAGES.length;
    updateJourney();
  }

  updateJourney();
  const interval = setInterval(advance, 4200);

  // Clean up on navigation (Astro view transitions)
  document.addEventListener("astro:before-swap", () => clearInterval(interval));
</script>

<style>
  /* ── Hero section ────────────────────────────────── */

  .hero-section {
    padding: 96px 0 56px;
    overflow: hidden;
    position: relative;
  }

  @media (min-width: 1024px) {
    .hero-section { padding: 144px 0 88px; }
  }

  /* Pre-title row */
  .hero-pre {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-muted);
    font-family: "JetBrains Mono", "IBM Plex Mono", ui-monospace, monospace;
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .hero-pre-text { transform: translateY(1px); }

  /* Two-column grid */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
      gap: 64px;
      align-items: end;
    }
  }

  /* Display H1 */
  .hero-h1 {
    font-family: "Inter Display", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-feature-settings: "ss01", "cv11", "ss03";
    font-weight: 500;
    font-size: clamp(44px, 8.2vw, 108px);
    letter-spacing: -0.035em;
    line-height: 0.94;
    color: var(--text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .h1-row { display: block; }

  .h1-x {
    color: var(--accent);
    font-weight: 600;
    display: inline-block;
    margin-left: 0.08em;
  }

  /* Sub copy */
  .hero-sub {
    margin-top: 32px;
    max-width: 56ch;
    font-size: clamp(16px, 1.5vw, 20px);
    line-height: 1.5;
    color: var(--text-secondary);
  }

  /* CTA row */
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 36px;
  }

  .hero-cta-primary {
    height: 48px;
    padding: 0 22px;
    font-size: 15px;
  }

  .button-secondary {
    height: 48px;
    padding: 0 22px;
    font-size: 15px;
  }

  /* Meta strip */
  .hero-meta {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 24px;
    align-items: center;
  }

  .hm-item {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }

  .hm-k {
    font-family: "JetBrains Mono", "IBM Plex Mono", ui-monospace, monospace;
    font-size: 10.5px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hm-v {
    font-family: "JetBrains Mono", "IBM Plex Mono", ui-monospace, monospace;
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* ── Thesis section ──────────────────────────────── */

  .thesis-h2 {
    font-family: "Inter Display", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-feature-settings: "ss01", "cv11", "ss03";
    font-weight: 500;
    font-size: clamp(26px, 4vw, 52px);
    letter-spacing: -0.02em;
    line-height: 1.08;
    color: var(--text-primary);
    margin-top: 10px;
    text-wrap: balance;
  }

  .h2-dim {
    font-style: normal;
    color: var(--text-secondary);
  }

  .section.tight { padding-block: 64px; }

  @media (min-width: 1024px) {
    .section.tight { padding-block: 88px; }
  }

  /* ── CTA strip ───────────────────────────────────── */

  .cta-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
  }

  @media (min-width: 900px) {
    .cta-split {
      grid-template-columns: 1.5fr 1fr;
      gap: 64px;
    }
  }

  .cta-body {
    margin-top: 16px;
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .cta-right {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  /* ── Light mode overrides (critical for readability) ── */

  [data-theme="light"] .hero-section {
    background: var(--bg-base);
  }

  [data-theme="light"] .bento-cell {
    background: var(--bg-elevated);
    border-color: var(--border-subtle);
  }

  [data-theme="light"] .badge-cell {
    background: var(--bg-base);
  }

  [data-theme="light"] .badge-cell:hover {
    background: var(--bg-elevated);
  }

  [data-theme="light"] .step-item {
    background: var(--bg-base);
  }

  [data-theme="light"] .journey {
    background: var(--bg-elevated);
  }

  [data-theme="light"] .journey-detail {
    background: var(--bg-sunken);
  }
</style>
