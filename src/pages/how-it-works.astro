---
import BaseLayout from "../layouts/BaseLayout.astro";
import { collectionPageSchema } from "../lib/seo";

const candidateSteps = [
  ["Apply", "Submit your profile, AI skill focus, LinkedIn, and NZ contact details."],
  ["Verify", "Take model and stack sandboxes. Pass tests to earn reusable tenX badges."],
  ["Prioritise", "More relevant badges increase match priority when employer demand opens."],
  ["Match", "Review opportunities where your verified skills map to the hiring brief."]
];

const employerSteps = [
  ["Brief", "Share role, location, budget, model stack, and the problems the engineer needs to own."],
  ["Shortlist", "tenX filters by badge evidence, availability, geography, and salary expectations."],
  ["Interview", "Talk to engineers who already cleared relevant sandboxes. Spend time on fit and scope."],
  ["Hire", "Use published 10% permanent or 20% contractor pricing. No hidden marketplace spread."]
];
---

<BaseLayout
  title="How tenX works"
  description="How engineers earn AI verification badges and how employers hire model-fluent engineers through tenX."
  path="/how-it-works"
  breadcrumbs={[{ name: "Home", path: "/" }, { name: "How it works", path: "/how-it-works" }]}
  schema={collectionPageSchema({
    title: "How tenX works",
    description: "Candidate verification and employer hiring process for AI-verified engineers.",
    path: "/how-it-works"
  })}
>
  <section class="container section">
    <div class="max-w-3xl">
      <p class="eyebrow">Process</p>
      <h1 class="mt-4 text-5xl font-medium leading-tight md:text-6xl">Verification first. Matching second.</h1>
      <p class="mt-6 text-xl leading-8 text-[var(--muted)]">
        tenX starts with candidates because the network needs verified supply before employer demand opens.
        The platform tests practical AI work across models, stacks, and production patterns.
      </p>
    </div>
  </section>

  <section class="border-y border-[var(--line)] bg-[var(--bg-elevated)]">
    <div class="container grid gap-10 py-16 lg:grid-cols-2">
      <div>
        <p class="eyebrow">For candidates</p>
        <h2 class="mt-4 text-4xl font-medium">Earn proof that travels.</h2>
        <div class="mt-8 grid gap-4">
          {candidateSteps.map(([title, body], index) => (
            <article class="card p-6">
              <p class="mono text-sm text-[var(--accent)]">0{index + 1}</p>
              <h3 class="mt-3 text-2xl font-medium">{title}</h3>
              <p class="mt-3 leading-7 text-[var(--muted)]">{body}</p>
            </article>
          ))}
        </div>
      </div>
      <div>
        <p class="eyebrow">For employers</p>
        <h2 class="mt-4 text-4xl font-medium">Hire from verified signal.</h2>
        <div class="mt-8 grid gap-4">
          {employerSteps.map(([title, body], index) => (
            <article class="card p-6">
              <p class="mono text-sm text-[var(--accent)]">0{index + 1}</p>
              <h3 class="mt-3 text-2xl font-medium">{title}</h3>
              <p class="mt-3 leading-7 text-[var(--muted)]">{body}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Sandbox tests</p>
        <h2 class="mt-4 text-4xl font-medium">The badges are the product.</h2>
      </div>
      <div class="prose-tenx max-w-none">
        <p>
          A tenX badge means the engineer passed a platform task in a bounded environment. Tests are stack and model specific:
          Claude fluency, GPT fluency, Gemini fluency, prompt engineering, RAG, agent design, evals, MLOps, and code-with-AI.
        </p>
        <p>
          The result is scalable verification. No founder call can evaluate 100 engineers with consistent criteria. A sandbox can.
          That matters for candidates because skill signal compounds, and it matters for employers because shortlists start closer to reality.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
