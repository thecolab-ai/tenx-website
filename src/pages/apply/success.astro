---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { href } from "../../lib/href";
---

<BaseLayout
  title="Application received"
  description="Your tenX application has been received. Next step: complete a practical skills assessment."
  path="/apply/success"
  breadcrumbs={[{ name: "Home", path: "/" }, { name: "Apply", path: "/apply" }, { name: "Success", path: "/apply/success" }]}
>
  <section class="container section">
    <div class="panel max-w-3xl p-8 md:p-10">
      <p class="eyebrow">Application received</p>
      <h1 class="mt-4 text-5xl font-medium leading-tight">Next: take a practical test.</h1>
      <p class="mt-5 text-xl leading-8 text-[var(--muted)]">
        Your profile is in the candidate intake queue. The next signal is badge evidence from a practical skills assessment.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <!-- TODO: switch back to https://app.tenxtalent.ai/ once app.tenxtalent.ai DNS is configured. -->
        <a class="button button-primary" href="https://tenxtalent.ai/">Open assessment</a>
        <a class="button button-secondary" href={href("/network")}>See badge breakdown</a>
      </div>
    </div>
  </section>
</BaseLayout>
