---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { jobPostingSchema } from "../../lib/seo";

const skills = [
  "Claude fluency",
  "OpenAI fluency",
  "Google fluency",
  "Prompt engineering",
  "RAG",
  "Agent design",
  "Evals",
  "MLOps",
  "Code-with-AI"
];

const features = [
  {
    eyebrow: "How it works",
    title: "Platform skill tests",
    body: "Each badge area has a bounded sandbox task — a real deliverable, not multiple choice. You run code, evaluate outputs, or design a system within a time limit. Results are platform-scored; no human gatekeeping."
  },
  {
    eyebrow: "What you earn",
    title: "Badges across Claude, OpenAI, Google, RAG, agents, evals, MLOps",
    body: "Pass a sandbox task and you earn the badge for that area. Badges are permanent, visible on your profile, and searchable by employers. More verified areas, more visibility in the network."
  },
  {
    eyebrow: "How matching works",
    title: "Higher match priority for stronger evidence",
    body: "Employers filter the network by badge. Engineers with verified evidence across more areas surface first. No recruiter pre-screens. Your badge count determines your placement rank."
  }
];
---

<BaseLayout
  title="Apply as an AI engineer"
  description="Apply to join the tenX AI-verified engineering network. Candidate intake is open now for NZ and early AUS engineers."
  path="/apply"
  breadcrumbs={[{ name: "Home", path: "/" }, { name: "Apply", path: "/apply" }]}
  schema={jobPostingSchema({
    title: "AI-verified engineer network application",
    description: "Apply to join the tenX network and verify AI engineering skills through model and stack sandboxes.",
    path: "/apply"
  })}
>
  <section class="container grid gap-10 py-16 lg:grid-cols-[0.9fr_1.1fr] lg:py-24">
    <div>
      <p class="eyebrow">Candidate intake open</p>
      <h1 class="mt-4 text-5xl font-medium leading-tight md:text-6xl">Apply once. Verify in the sandbox. Get prioritised by proof.</h1>
      <p class="mt-6 text-xl leading-8 text-[var(--muted)]">
        The NZ-first network of sandbox-tested AI engineers. No recruiter calls, no screening interviews. Take the tests, earn badges, get matched to employers by evidence.
      </p>
      <div class="mt-8 grid gap-3">
        {features.map((f) => (
          <div class="card p-4">
            <p class="eyebrow mb-2 text-xs">{f.eyebrow}</p>
            <h4 class="font-bold leading-snug">{f.title}</h4>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{f.body}</p>
          </div>
        ))}
      </div>
    </div>

    <form class="panel grid gap-5 p-6 md:p-8" method="post" action="/api/apply">
      <input type="hidden" name="source" value="tenx-website-apply" />
      <label class="label">
        Full name
        <input class="input" name="name" autocomplete="name" required />
      </label>
      <label class="label">
        Email
        <input class="input" name="email" type="email" autocomplete="email" required />
      </label>
      <label class="label">
        LinkedIn URL
        <input class="input" name="linkedin" type="url" inputmode="url" placeholder="https://www.linkedin.com/in/..." required />
      </label>
      <label class="label">
        NZ phone
        <input class="input" name="phone" type="tel" autocomplete="tel" placeholder="+64 ..." required />
      </label>
      <label class="label">
        Current role
        <input class="input" name="current_role" placeholder="Senior software engineer, ML engineer, founder..." required />
      </label>
      <label class="label">
        Primary AI skill
        <select class="select" name="primary_ai_skill" required>
          <option value="">Select one</option>
          {skills.map((skill) => <option value={skill}>{skill}</option>)}
        </select>
      </label>
      <button class="button button-primary" type="submit">Apply as an engineer</button>
      <p class="text-sm leading-6 text-[var(--faint)]">
        Next step after applying: take a sandbox test at app.tenxtalent.ai. Intake is open now for NZ engineers; AUS opens June 2026.
      </p>
    </form>
  </section>
</BaseLayout>
