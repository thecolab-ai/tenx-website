---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { jobPostingSchema } from "../../lib/seo";
import { href } from "../../lib/href";

const skills = [
  "Claude fluency",
  "OpenAI fluency",
  "Google fluency",
  "Prompt engineering",
  "RAG",
  "Agent design",
  "Evals",
  "MLOps",
  "Code-with-AI"
];

const features = [
  {
    eyebrow: "How it works",
    title: "Platform skill tests",
    body: "Each badge area has a practical task with a real deliverable, not multiple choice. You run code, evaluate outputs, or design a system within a time limit."
  },
  {
    eyebrow: "What you earn",
    title: "Badges across Claude, OpenAI, Google, RAG, agents, evals, MLOps",
    body: "Pass a practical test and you earn the badge for that area. Badges are permanent, visible on your profile, and searchable by employers."
  },
  {
    eyebrow: "How matching works",
    title: "Higher match priority for stronger evidence",
    body: "Employers filter the network by badge. Engineers with verified evidence across more areas surface first. No recruiter pre-screens. Your badge count determines your placement rank."
  }
];
---

<BaseLayout
  title="Apply as an AI engineer"
  description="Apply to join the tenX AI-verified engineering network. Candidate intake is open now for NZ and early AUS engineers."
  path="/apply"
  breadcrumbs={[{ name: "Home", path: "/" }, { name: "Apply", path: "/apply" }]}
  schema={jobPostingSchema({
    title: "AI-verified engineer network application",
    description: "Apply to join the tenX network and verify AI engineering skills through practical model and stack tests.",
    path: "/apply"
  })}
>
  <section class="container grid gap-10 py-16 lg:grid-cols-[0.9fr_1.1fr] lg:py-24">
    <div>
      <p class="eyebrow">Candidate intake open</p>
      <h1 class="mt-4 text-5xl font-medium leading-tight md:text-6xl">Apply once. Prove your skills. Get prioritised by evidence.</h1>
      <p class="mt-6 text-xl leading-8 text-[var(--muted)]">
        The NZ-first network of AI engineers verified through practical tests. Take the tests, earn badges, get matched to employers by evidence.
      </p>
      <div class="mt-8 grid gap-3">
        {features.map((f) => (
          <div class="card p-4">
            <p class="eyebrow mb-2 text-xs">{f.eyebrow}</p>
            <h4 class="font-bold leading-snug">{f.title}</h4>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{f.body}</p>
          </div>
        ))}
      </div>
      <p class="mt-5 text-sm text-[var(--muted)]">
        <a href={href("/vetting")} class="underline underline-offset-2 hover:text-[var(--ink)]">See what we test for →</a>
      </p>
    </div>

    <form class="panel grid gap-5 p-6 md:p-8" method="post" action="/api/apply" data-async-form="apply">
      <input type="hidden" name="source" value="tenx-website-apply" />
      <label class="label">
        Full name
        <input class="input" name="name" autocomplete="name" required />
      </label>
      <label class="label">
        Email
        <input class="input" name="email" type="email" autocomplete="email" required />
      </label>
      <label class="label">
        LinkedIn URL
        <input class="input" name="linkedin" type="url" inputmode="url" placeholder="https://www.linkedin.com/in/..." required />
      </label>
      <label class="label">
        NZ phone
        <input class="input" name="phone" type="tel" autocomplete="tel" placeholder="+64 ..." required />
      </label>
      <label class="label">
        Current role
        <input class="input" name="current_role" placeholder="Senior software engineer, ML engineer, contractor..." required />
      </label>
      <label class="label">
        Primary AI skill
        <select class="select" name="primary_ai_skill" required>
          <option value="">Select one</option>
          {skills.map((skill) => <option value={skill}>{skill}</option>)}
        </select>
      </label>
      <button class="button button-primary" type="submit">Apply to the network</button>
      <p data-form-status class="text-sm leading-6 text-[var(--faint)]" aria-live="polite" hidden></p>
      <p class="text-sm leading-6 text-[var(--faint)]">
        {/* TODO: switch back to https://app.tenxtalent.ai/ once app.tenxtalent.ai DNS is configured. */}
        Next step after applying: take a practical skills assessment at <a href="https://tenxtalent.ai/" class="underline underline-offset-2 hover:text-[var(--ink)]">tenxtalent.ai</a>. Intake is open now for NZ candidates; AUS opens June 2026.
      </p>
    </form>
  </section>

  <script>
    type FormResult = {
      errors?: Array<{ message?: string }>;
      message?: string;
      ok?: boolean;
      redirect?: string;
    };

    const form = document.querySelector("[data-async-form='apply']");

    if (form instanceof HTMLFormElement) {
      const status = form.querySelector("[data-form-status]");
      const submitButton = form.querySelector("button[type='submit']");
      const initialButtonText = submitButton?.textContent ?? "";

      const setStatus = (message: string, state: "error" | "muted" | "success" = "muted") => {
        if (!(status instanceof HTMLElement)) return;

        status.hidden = !message;
        status.textContent = message;
        status.style.color =
          state === "error" ? "var(--danger)" : state === "success" ? "var(--success)" : "var(--faint)";
      };

      const messageFromResult = (result: FormResult) => {
        if (Array.isArray(result?.errors)) {
          const errorMessage = result.errors.map((error) => error?.message).filter(Boolean).join(" ");
          if (errorMessage) return errorMessage;
        }

        return result?.message || "Could not submit the application. Please email mail@adamholt.co.nz directly.";
      };

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        let shouldRestore = true;
        setStatus("Sending application...", "muted");

        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.textContent = "Sending...";
        }

        try {
          const response = await fetch(form.action, {
            method: form.method || "POST",
            body: new FormData(form),
            headers: { Accept: "application/json" }
          });
          const result = (await response.json().catch(() => ({}))) as FormResult;

          if (!response.ok || !result?.ok) {
            setStatus(messageFromResult(result), "error");
            return;
          }

          setStatus(result.message || "Application received.", "success");

          if (typeof result.redirect === "string") {
            shouldRestore = false;
            window.location.assign(result.redirect);
          }
        } catch {
          setStatus("Could not submit the application. Please email mail@adamholt.co.nz directly.", "error");
        } finally {
          if (shouldRestore && submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
            submitButton.textContent = initialButtonText;
          }
        }
      });
    }
  </script>
</BaseLayout>
