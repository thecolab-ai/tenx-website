{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowJs": false,
    "exactOptionalPropertyTypes": true,
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["astro/client", "@cloudflare/workers-types"]
  },
  "include": ["src", "functions", "astro.config.mjs"]
}
